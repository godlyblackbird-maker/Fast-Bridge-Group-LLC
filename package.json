{
  "name": "fast-investments-dashboard",
  "version": "1.4.4",
  "description": "Secure Investment Dashboard",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "share": "node scripts/share-link.js",
    "desktop:icon": "node scripts/generate-desktop-icon.js",
    "desktop": "electron .",
    "desktop:dev": "electron .",
    "desktop:pack": "electron-builder --dir",
    "desktop:dist": "electron-builder --win nsis",
    "desktop:bundle": "electron-packager . \"FAST BRIDGE GROUP\" --platform=win32 --arch=x64 --icon=build/app-icon.ico --out=dist/electron-packager --overwrite --ignore=dist --ignore=node_modules/.cache --ignore=temp --ignore=.git"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@aws-sdk/lib-storage": "^3.1021.0",
    "@stripe/stripe-js": "^8.11.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "sqlite3": "^5.0.11",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "nodemon": "^3.1.14",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godlyblackbird-maker/Fast-Bridge-Group-LLC.git"
  },
  "bugs": {
    "url": "https://github.com/godlyblackbird-maker/Fast-Bridge-Group-LLC/issues"
  },
  "homepage": "https://github.com/godlyblackbird-maker/Fast-Bridge-Group-LLC#readme",
  "build": {
    "appId": "com.fastbridgegroup.desktop",
    "productName": "FAST BRIDGE GROUP",
    "asar": false,
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "electron/**/*",
      "*.html",
      "*.js",
      "*.css",
      "*.json",
      "*.svg",
      "*.ico",
      "*.png",
      "build/**/*",
      "favicon*",
      "fast-logo.svg",
      "Fast Logo.png",
      "site.webmanifest",
      "render.yaml",
      "README.md",
      "SETUP_GUIDE.md",
      "Themes/**/*",
      "Symbols/**/*",
      "Fonts/**/*",
      "scripts/**/*",
      "sendEmail.js/**/*",
      "CRMLS/**/*",
      "png photos/**/*",
      "2026 Real Estate Laws/**/*",
      "Apprasial Rules/**/*",
      "Bible Verse/**/*",
      "Calculator/**/*",
      "Contracts/**/*",
      "Counties - Cities - Buying Box/**/*",
      "Email - Offer Terms/**/*",
      "Investors Attatchments/**/*",
      "PDF Example/**/*",
      "Sound FX/**/*",
      "USERS/**/*",
      "Youtube/**/*",
      "package.json",
      "package-lock.json",
      "server.js",
      "auth.js",
      "login.js",
      "profile.js",
      "register.js",
      ".env"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": "nsis",
      "icon": "build/app-icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp"
    }
  }
}
